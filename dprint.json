{
  "biome": {
    "indentStyle": "space",
    "indentWidth": 2,
    "json.indentStyle": "space",
    "json.indentWidth": 2
  },
  "exec": {
    "commands": [
      {
        "command": "alejandra --quiet",
        "exts": ["nix"],
        "stdin": true
      },
      {
        "command": "shfmt",
        "exts": ["bash", "sh"]
      }
    ]
  },
  "excludes": [
    "**/.git/**",
    "**/.nvfetcher/**",
    "**/locks/**",
    "**/node_modules/**",
    "**/result/**"
  ],
  "includes": ["**/*.json", "**/*.md", "**/*.nix", "**/*.sh", "**/*.toml"],
  "markdown": {
    "lineWidth": 80
  },
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/biome-0.12.5.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463"
  ],
  "toml": {}
}
