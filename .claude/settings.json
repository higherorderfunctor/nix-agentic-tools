{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; [[ -f \"$f\" ]] && dprint fmt \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting...",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"${f##*/}\" in CLAUDE.md|AGENTS.md|SKILL.md|.agnix.toml|settings.json|.mcp.json|copilot-instructions.md|*.instructions.md) ;; *) exit 0;; esac; output=$(agnix --strict . 2>&1); rc=$?; if [ $rc -ne 0 ]; then jq -n --arg ctx \"agnix --strict found issues after editing $f:\\n$output\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":$ctx}}'; fi; }",
            "statusMessage": "Linting agent configs...",
            "timeout": 120,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(dprint:*)",
      "Bash(git absorb*)",
      "Bash(git add*)",
      "Bash(git amend*)",
      "Bash(git branch*)",
      "Bash(git branchless*)",
      "Bash(git diff*)",
      "Bash(git hide*)",
      "Bash(git log*)",
      "Bash(git move*)",
      "Bash(git next*)",
      "Bash(git prev*)",
      "Bash(git query*)",
      "Bash(git record*)",
      "Bash(git reset HEAD*)",
      "Bash(git restack*)",
      "Bash(git restore --staged*)",
      "Bash(git revise*)",
      "Bash(git reword*)",
      "Bash(git show*)",
      "Bash(git sl*)",
      "Bash(git smartlog*)",
      "Bash(git split*)",
      "Bash(git status*)",
      "Bash(git submit*)",
      "Bash(git sw*)",
      "Bash(git sync*)",
      "Bash(git test*)",
      "Bash(git undo*)",
      "Bash(git unhide*)",
      "Bash(head:*)",
      "Read(references/*)"
    ],
    "ask": [
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)"
    ]
  }
}
