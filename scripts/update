#!/usr/bin/env bash

set -euETo pipefail
shopt -s inherit_errexit 2>/dev/null || :

cd "$(dirname "$0")/.."

NVFETCHER_OUT=".nvfetcher"
LOCKS_AI="packages/ai-clis/locks"
LOCKS_MCP="packages/mcp-servers/locks"
HASHES_AI="packages/ai-clis/hashes.json"
HASHES_GIT="packages/git-tools/hashes.json"
HASHES_MCP="packages/mcp-servers/hashes.json"

log() { echo "==> $*" >&2; }

inject_hash() {
  local file=$1 key=$2 field=$3 value=$4
  local tmp
  tmp=$(mktemp)
  jq --arg key "$key" --arg field "$field" --arg val "$value" \
    '.[$key][$field] = $val' "$file" >"$tmp" && mv "$tmp" "$file"
}

# ── 1. Flake inputs ─────────────────────────────────────────────
log "Updating flake inputs"
nix flake update
git add flake.lock

# ── 2. nvfetcher (single run, single output) ────────────────────
log "Running nvfetcher"
nvfetcher -c nvfetcher.toml -o "$NVFETCHER_OUT"

log "Formatting generated files"
treefmt "$NVFETCHER_OUT/generated.nix"

# Stage generated output so nix build can see it
git add "$NVFETCHER_OUT"

# ── 3. Refresh npm lock files ────────────────────────────────────
refresh_lock_tarball() {
  local locks_dir=$1 name=$2 nv_key=$3
  local url
  url=$(jq -r ".\"$nv_key\".src.url" "$NVFETCHER_OUT/generated.json")
  local tmp
  tmp=$(mktemp -d)

  log "Refreshing lock for $name"
  curl -sL "$url" | tar xz -C "$tmp"
  (cd "$tmp/package" && npm install --package-lock-only --ignore-scripts --silent 2>/dev/null)
  cp "$tmp/package/package-lock.json" "$locks_dir/${name}-package-lock.json"
  rm -rf "$tmp"
}

refresh_lock_git() {
  local locks_dir=$1 name=$2 nv_key=$3
  local url rev
  url=$(jq -r ".\"$nv_key\".src.url" "$NVFETCHER_OUT/generated.json")
  rev=$(jq -r ".\"$nv_key\".src.rev" "$NVFETCHER_OUT/generated.json")
  local tmp
  tmp=$(mktemp -d)

  log "Refreshing lock for $name (${rev:0:12})"
  git clone --depth 1 "$url" "$tmp/repo" 2>/dev/null
  (cd "$tmp/repo" && npm install --package-lock-only --ignore-scripts --silent 2>/dev/null)
  cp "$tmp/repo/package-lock.json" "$locks_dir/${name}-package-lock.json"
  rm -rf "$tmp"
}

# AI CLIs
refresh_lock_tarball "$LOCKS_AI" claude-code claude-code

# MCP servers
refresh_lock_tarball "$LOCKS_MCP" context7-mcp context7-mcp
refresh_lock_tarball "$LOCKS_MCP" openmemory-mcp openmemory-mcp
refresh_lock_tarball "$LOCKS_MCP" sequential-thinking-mcp sequential-thinking-mcp
refresh_lock_git "$LOCKS_MCP" git-intel-mcp git-intel-mcp

# ── 4. Inject npmDepsHash ────────────────────────────────────────
update_npm_hash() {
  local hashes_file=$1 locks_dir=$2 name=$3 nv_key=$4
  local lock="$locks_dir/${name}-package-lock.json"

  log "Prefetching npmDepsHash for $name"
  local hash
  hash=$(prefetch-npm-deps "$lock" 2>/dev/null)
  inject_hash "$hashes_file" "$nv_key" "npmDepsHash" "$hash"
}

# AI CLIs
update_npm_hash "$HASHES_AI" "$LOCKS_AI" claude-code claude-code

# MCP servers
update_npm_hash "$HASHES_MCP" "$LOCKS_MCP" context7-mcp context7-mcp
update_npm_hash "$HASHES_MCP" "$LOCKS_MCP" git-intel-mcp git-intel-mcp
update_npm_hash "$HASHES_MCP" "$LOCKS_MCP" openmemory-mcp openmemory-mcp
update_npm_hash "$HASHES_MCP" "$LOCKS_MCP" sequential-thinking-mcp sequential-thinking-mcp

# ── 4b. Inject fetchzip srcHash (tarball→unpacked) ───────────────
update_src_hash() {
  local hashes_file=$1 nv_key=$2
  local url
  url=$(jq -r ".\"$nv_key\".src.url" "$NVFETCHER_OUT/generated.json")

  log "Prefetching srcHash for $nv_key"
  local base32
  base32=$(nix-prefetch-url --unpack --type sha256 "$url" 2>/dev/null)
  local hash
  hash=$(nix hash convert --hash-algo sha256 --to sri "$base32")
  inject_hash "$hashes_file" "$nv_key" "srcHash" "$hash"
}

# AI CLIs (fetchzip needs unpacked hash, not fetchurl hash)
update_src_hash "$HASHES_AI" claude-code

# ── 5. Inject Go vendorHash (only if version changed) ───────────
update_vendor_hash() {
  local hashes_file=$1 nv_key=$2 pkg=$3
  local old_hash
  old_hash=$(jq -r ".\"$nv_key\".vendorHash // empty" "$hashes_file")

  # Try building with current hash first — skip if it works
  if [[ -n "$old_hash" ]] && nix build ".#$pkg" --no-link 2>/dev/null; then
    log "vendorHash for $nv_key is current, skipping"
    return
  fi

  log "Prefetching vendorHash for $nv_key"
  inject_hash "$hashes_file" "$nv_key" "vendorHash" \
    "sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
  git add "$hashes_file"

  local hash
  hash=$(
    nix build ".#$pkg" 2>&1 |
      grep -oP 'got:\s+\Ksha256-[A-Za-z0-9+/=]+' |
      head -1
  ) || true

  if [[ -n "$hash" ]]; then
    inject_hash "$hashes_file" "$nv_key" "vendorHash" "$hash"
  else
    log "WARNING: could not determine vendorHash for $nv_key"
    inject_hash "$hashes_file" "$nv_key" "vendorHash" "$old_hash"
  fi
}

update_vendor_hash "$HASHES_MCP" "github-mcp-server" "github-mcp"
update_vendor_hash "$HASHES_MCP" "mcp-language-server" "mcp-language-server"

# ── 6. Inject Rust cargoHash (only if version changed) ──────────
update_cargo_hash() {
  local hashes_file=$1 nv_key=$2 pkg=$3
  local old_hash
  old_hash=$(jq -r ".\"$nv_key\".cargoHash // empty" "$hashes_file")

  # Try building with current hash first — skip if it works
  if [[ -n "$old_hash" ]] && nix build ".#$pkg" --no-link 2>/dev/null; then
    log "cargoHash for $nv_key is current, skipping"
    return
  fi

  log "Prefetching cargoHash for $nv_key"
  inject_hash "$hashes_file" "$nv_key" "cargoHash" \
    "sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
  git add "$hashes_file"

  local hash
  hash=$(
    nix build ".#$pkg" 2>&1 |
      grep -oP 'got:\s+\Ksha256-[A-Za-z0-9+/=]+' |
      head -1
  ) || true

  if [[ -n "$hash" ]]; then
    inject_hash "$hashes_file" "$nv_key" "cargoHash" "$hash"
  else
    log "WARNING: could not determine cargoHash for $nv_key"
    inject_hash "$hashes_file" "$nv_key" "cargoHash" "$old_hash"
  fi
}

update_cargo_hash "$HASHES_GIT" "agnix" "agnix"
update_cargo_hash "$HASHES_GIT" "git-absorb" "git-absorb"
update_cargo_hash "$HASHES_GIT" "git-branchless" "git-branchless"

# ── 7. Verify ──────────────────────────────────────────────────
log "Staging changes"
git add -A

log "Verifying all packages evaluate"
nix flake check --no-build 2>&1 | tail -3 || true

log "Done — review changes with: git diff --cached"
