# Build artifacts
result
result-*
result-docs

# Claude Code plugin state
.remember/

# devenv state
.devenv/
.direnv/

# devenv nix store symlinks inside skill source directories
packages/stacked-workflows/skills/*/[0-9a-z]*-*

# Generated by devenv (materialized as symlinks on shell entry).
# Copilot custom instruction files and AGENTS.md are exceptions
# below — they are generated AND committed so the GitHub-hosted
# Copilot reviewer (which reads instructions from the head commit,
# not from a build step) sees the project's custom instructions.
# Per https://github.blog/changelog/2025-08-28-copilot-coding-agent-now-supports-agents-md-custom-instructions/
# the hosted reviewer reads `.github/copilot-instructions.md`,
# `.github/instructions/*.instructions.md`, AND `AGENTS.md`.
.claude/rules/
.claude/settings.json
.claude/settings.local.json
.claude/skills/
.copilot/
.github/skills/
.kiro/settings/
.kiro/skills/
.kiro/steering/
.mcp.json
.pre-commit-config.yaml
CLAUDE.md
# (intentionally NOT ignored — committed for hosted reviewer)
# .github/copilot-instructions.md
# .github/instructions/
# AGENTS.md

# Generated doc site (mdbook source, built from dev/docs/ + nix eval)
docs/src/

# nvfetcher shake database (not the generated output)
/.nvfetcher/.shake.*
