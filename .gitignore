# Build artifacts
result
result-*
result-docs

# Claude Code plugin state
.remember/

# devenv state
.devenv/
.direnv/

# devenv nix store symlinks inside skill source directories
packages/stacked-workflows/skills/*/[0-9a-z]*-*

# Generated by devenv (materialized as symlinks on shell entry).
# Copilot instruction files are an exception below — they are
# generated AND committed so the GitHub-hosted Copilot reviewer
# (which reads instructions from the head commit, not from a build
# step) sees the project's custom instructions.
.claude/rules/
.claude/settings.json
.claude/settings.local.json
.claude/skills/
.copilot/
.github/skills/
.kiro/settings/
.kiro/skills/
.kiro/steering/
.mcp.json
.pre-commit-config.yaml
AGENTS.md
CLAUDE.md
# (intentionally NOT ignored — committed for hosted reviewer)
# .github/copilot-instructions.md
# .github/instructions/

# Generated doc site (mdbook source, built from dev/docs/ + nix eval)
docs/src/

# nvfetcher shake database (not the generated output)
/.nvfetcher/.shake.*
